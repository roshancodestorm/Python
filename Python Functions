# 1. Built-in Function: print()
# ------------------------------------------
print("Roshan", end="$")
print("Roshan")

# Output:
# Roshan$Roshan


# ------------------------------------------
# 2. Built-in Function: len()
# ------------------------------------------
name = "Roshan"
print(len(name))

# Output:
# 6


# ------------------------------------------
# 3. Built-in Function: type()
# ------------------------------------------
a = 10
print(type(a))

# Output:
# <class 'int'>


# ------------------------------------------
# 4. Built-in Function: range()
# ------------------------------------------
for i in range(5):
    print(i)

# Output:
# 0
# 1
# 2
# 3
# 4


# ------------------------------------------
# 5. User Defined Function
# ------------------------------------------
cities = ["delhi", "gurgaon", "noida", "pune", "mumbai", "chennai"]
heroes = ["thor", "ironman", "captain america", "shaktiman"]

def print_len(lst):
    print(len(lst))

print_len(cities)
print_len(heroes)

# Output:
# 6
# 4


# ------------------------------------------
# 6. Factorial Without Function
# ------------------------------------------
n = 5
fact = 1

for i in range(1, n + 1):
    fact *= i

print(fact)

# Output:
# 120


# ------------------------------------------
# 7. Factorial Using Function
# ------------------------------------------
def cal_fact(n):
    fact = 1

    for i in range(1, n + 1):
        fact *= i

    print(fact)

cal_fact(6)

# Output:
# 720


# ------------------------------------------
# 8. Average Calculator Function
# ------------------------------------------
def calc_avg(a, b, c):
    total = a + b + c
    avg = total / 3
    print(avg)

calc_avg(90, 97, 95)

# Output:
# 94.0


# ------------------------------------------
# 9. USD to INR Converter
# ------------------------------------------
def converter(usd_val):
    inr_val = usd_val * 83
    print(usd_val, "USD =", inr_val, "INR")

converter(10)

# Output:
# 10 USD = 830 INR
